<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mening Portfolio</title>
  <style>
    /* Umumiy dizayn */
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f5f5f5;
      text-align: center;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    /* Hero bo‘limi */
    .hero {
      height: 100vh;
      background: linear-gradient(to right, #4facfe, #00f2fe);
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hero h1 {
      font-size: 3em;
      margin: 0.2em;
    }

    .hero p {
      font-size: 1.2em;
    }

    .hero button {
      padding: 12px 25px;
      font-size: 1em;
      margin-top: 20px;
      border: none;
      border-radius: 5px;
      background-color: white;
      color: #4facfe;
      cursor: pointer;
      transition: 0.3s;
    }

    .hero button:hover {
      background-color: #e0e0e0;
    }

    /* Bo‘limlar */
    section {
      padding: 60px 20px;
    }

    h2 {
      font-size: 2em;
      margin-bottom: 20px;
      color: #333;
    }

    /* About bo‘limi */
    .about img {
      width: 150px;
      border-radius: 50%;
    }

    .skills {
      margin-top: 20px;
    }

    .skills span {
      display: inline-block;
      background-color: #4facfe;
      color: white;
      padding: 5px 10px;
      margin: 5px;
      border-radius: 20px;
      font-size: 0.9em;
    }

    /* Projects bo‘limi */
    .projects {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 20px;
    }

    .project-card {
      background-color: white;
      width: 250px;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.1);
      transition: transform 0.3s;
    }

    .project-card:hover {
      transform: translateY(-5px);
    }

    .project-card img {
      width: 100%;
      border-radius: 8px;
    }

    /* Contact bo‘limi */
    .contact form {
      display: flex;
      flex-direction: column;
      max-width: 400px;
      margin: auto;
    }

    .contact input, .contact textarea {
      padding: 10px;
      margin: 10px 0;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    .contact button {
      padding: 12px;
      border: none;
      border-radius: 5px;
      background-color: #4facfe;
      color: white;
      cursor: pointer;
      transition: 0.3s;
    }

    .contact button:hover {
      background-color: #00f2fe;
    }

    /* Footer */
    footer {
      background-color: #333;
      color: white;
      padding: 20px;
    }
  </style>
</head>
<body>

  <!-- Hero Section -->
  <div class="hero">
    <h1>Ismingiz Familiyangiz</h1>
    <p>Men dasturchi va veb-ishlab chiquvchiman</p>
    <button onclick="document.querySelector('.contact').scrollIntoView({behavior:'smooth'})">Kontaktga o'tish</button>
  </div>

  <!-- About Section -->
  <section class="about">
    <h2>About Me</h2>
    <img src="https://via.placeholder.com/150" alt="Profile Photo">
    <p>Men professional web va mobil dasturchiman. HTML, CSS, JS va React bilan ishlayman.</p>
    <div class="skills">
      <span>HTML</span>
      <span>CSS</span>
      <span>JavaScript</span>
      <span>React</span>
      <span>Python</span>
    </div>
  </section>

  <!-- Projects Section -->
  <section class="projects-section">
    <h2>Projects</h2>
    <div class="projects">
      <div class="project-card">
        <img src="https://via.placeholder.com/250x150" alt="Project">
        <h3>Project 1</h3>
        <p>Short description of project 1.</p>
      </div>
      <div class="project-card">
        <img src="https://via.placeholder.com/250x150" alt="Project">
        <h3>Project 2</h3>
        <p>Short description of project 2.</p>
      </div>
      <div class="project-card">
        <img src="https://via.placeholder.com/250x150" alt="Project">
        <h3>Project 3</h3>
        <p>Short description of project 3.</p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact">
    <h2>Contact Me</h2>
    <form>
      <input type="text" placeholder="Ismingiz">
      <input type="email" placeholder="Email">
      <textarea rows="5" placeholder="Xabar"></textarea>
      <button type="submit">Yuborish</button>
    </form>
  </section>

  <!-- Footer -->
  <footer>
    <p>© 2026 Ismingiz. Barcha huquqlar himoyalangan.</p>
  </footer>

  <script>
    // Button smooth scroll allaqachon ishladi HTMLdagi onclick bilan
  </script>

</body>
</html>
